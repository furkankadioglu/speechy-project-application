<Window x:Class="Speechy.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speechy"
        Width="300" Height="350"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1A1A26" Offset="0" />
                <GradientStop Color="#0D0D1A" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>

            <!-- App Icon: gradient circle with mic -->
            <Grid Grid.Row="1" Width="120" Height="120" HorizontalAlignment="Center">
                <Ellipse>
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#007AFF" Offset="0" />
                            <GradientStop Color="#AF52DE" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#007AFF" BlurRadius="20" ShadowDepth="10"
                                          Direction="270" Opacity="0.5" />
                    </Ellipse.Effect>
                </Ellipse>
                <!-- Mic icon using Segoe MDL2 Assets -->
                <TextBlock Text="&#xE720;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="50"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- App Name -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,30,0,0">
                <TextBlock Text="Speechy"
                           FontSize="42"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           Foreground="White"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Speech to Text"
                           FontSize="16"
                           FontWeight="Medium"
                           Foreground="#99FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Progress Bar and Loading Text -->
            <StackPanel Grid.Row="4" HorizontalAlignment="Center" Margin="0,0,0,0">
                <Grid Width="200" Height="6">
                    <!-- Background track -->
                    <Border CornerRadius="3"
                            Background="#1AFFFFFF" />
                    <!-- Progress fill -->
                    <Border x:Name="ProgressFill"
                            CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#007AFF" Offset="0" />
                                <GradientStop Color="#AF52DE" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
                <TextBlock Text="Loading..."
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="#80FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
