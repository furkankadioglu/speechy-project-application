<Window x:Class="Speechy.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Speechy.Views.Controls"
        Title="Speechy Overlay"
        Width="120" Height="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        IsHitTestVisible="False">

    <!-- Dark rounded container matching macOS overlay (120x150, corner radius 20) -->
    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Background>
            <SolidColorBrush Color="Black" Opacity="0.8" />
        </Border.Background>

        <Grid>
            <!-- Speechy Icon: gradient circle + mic + flag badge -->
            <Grid x:Name="SpeechyIconPanel"
                  Width="48" Height="48"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="0,55,0,0"
                  Visibility="Collapsed">

                <!-- Gradient circle -->
                <Ellipse>
                    <Ellipse.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#007AFF" Offset="0" />
                            <GradientStop Color="#AF52DE" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Mic icon -->
                <TextBlock Text="&#xE720;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <!-- Flag badge -->
                <Grid x:Name="FlagBadge"
                      Width="20" Height="20"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,-4,-4">
                    <Ellipse Fill="#80000000" />
                    <TextBlock x:Name="FlagText"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>

            <!-- Waveform control -->
            <controls:WaveformControl x:Name="WaveformView"
                                      Width="100" Height="28"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Bottom"
                                      Margin="0,0,0,15"
                                      Visibility="Collapsed" />

            <!-- Spinner for processing state -->
            <Grid x:Name="SpinnerPanel"
                  Width="40" Height="40"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="0,10,0,0"
                  Visibility="Collapsed">
                <TextBlock x:Name="SpinnerIcon"
                           Text="&#xE117;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="SpinnerTransform"
                                         CenterX="12" CenterY="12" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</Window>
