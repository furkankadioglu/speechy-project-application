<UserControl x:Class="Speechy.Views.Tabs.AdvancedTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="20">

            <!-- ========== Section: AI Model ========== -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE99A;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#8B5CF6"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="AI Model"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <Border Background="#2D2D42" CornerRadius="12" Padding="16">
                    <StackPanel x:Name="ModelOptionsPanel">
                        <!-- Model options generated in code-behind -->
                    </StackPanel>
                </Border>

                <!-- Download error -->
                <TextBlock x:Name="DownloadErrorText"
                           FontSize="12" Foreground="#EF4444"
                           Margin="8,8,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ========== Section: Activation Delay ========== -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE916;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#F97316"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Activation Delay"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <Border Background="#2D2D42" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Delay Duration"
                                       FontSize="13" Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left" />
                            <Border HorizontalAlignment="Right"
                                    Background="#26F97316" CornerRadius="6"
                                    Padding="10,4">
                                <TextBlock x:Name="DelayValueText"
                                           FontSize="13" FontWeight="Bold"
                                           FontFamily="Segoe UI"
                                           Foreground="#F97316" />
                            </Border>
                        </Grid>

                        <Slider x:Name="DelaySlider"
                                Minimum="0" Maximum="500" TickFrequency="50"
                                IsSnapToTickEnabled="True"
                                ValueChanged="DelaySlider_ValueChanged" />

                        <TextBlock Text="Hold the hotkey for this duration to prevent accidental triggers"
                                   FontSize="12" Foreground="#A0A0B8"
                                   Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ========== Section: Voice Input ========== -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE720;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#06B6D4"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Voice Input"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <Border Background="#2D2D42" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xEC61;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#06B6D4"
                                       Width="28" VerticalAlignment="Center" />
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="Input Device"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="White" />
                                <TextBlock Text="Select which microphone to use for recording"
                                           FontSize="12" Foreground="#A0A0B8" />
                            </StackPanel>
                        </StackPanel>

                        <ComboBox x:Name="InputDeviceCombo"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="InputDeviceCombo_SelectionChanged" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ========== Section: Waveform Sensitivity — HIDDEN, uncomment to restore ==========
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xEC61;" FontFamily="Segoe MDL2 Assets" FontSize="14" FontWeight="SemiBold" Foreground="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Waveform Sensitivity" FontSize="16" FontWeight="SemiBold" Foreground="White" />
                </StackPanel>
                <Border Background="#2D2D42" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Multiplier" FontSize="13" Foreground="White" HorizontalAlignment="Left" />
                                <Border HorizontalAlignment="Right" Background="#2622C55E" CornerRadius="6" Padding="10,4">
                                    <TextBlock x:Name="MultiplierValueText" FontSize="13" FontWeight="Bold" Foreground="#22C55E" />
                                </Border>
                            </Grid>
                            <Slider x:Name="MultiplierSlider" Minimum="100" Maximum="2000" TickFrequency="50" IsSnapToTickEnabled="True" ValueChanged="MultiplierSlider_ValueChanged" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Exponent" FontSize="13" Foreground="White" HorizontalAlignment="Left" />
                                <Border HorizontalAlignment="Right" Background="#2622C55E" CornerRadius="6" Padding="10,4">
                                    <TextBlock x:Name="ExponentValueText" FontSize="13" FontWeight="Bold" Foreground="#22C55E" />
                                </Border>
                            </Grid>
                            <Slider x:Name="ExponentSlider" Minimum="0.05" Maximum="0.5" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="ExponentSlider_ValueChanged" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Divisor" FontSize="13" Foreground="White" HorizontalAlignment="Left" />
                                <Border HorizontalAlignment="Right" Background="#2622C55E" CornerRadius="6" Padding="10,4">
                                    <TextBlock x:Name="DivisorValueText" FontSize="13" FontWeight="Bold" Foreground="#22C55E" />
                                </Border>
                            </Grid>
                            <Slider x:Name="DivisorSlider" Minimum="0.1" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="DivisorSlider_ValueChanged" />
                        </StackPanel>
                        <TextBlock Text="Adjust waveform visualization sensitivity. Higher multiplier &amp; lower exponent = more sensitive." FontSize="12" Foreground="#A0A0B8" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
            ========== End Waveform Sensitivity ========== -->

            <!-- ========== Section: General ========== -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#9CA3AF"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="General"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <Border Background="#2D2D42" CornerRadius="12">
                    <StackPanel>
                        <!-- Launch at Login -->
                        <Grid Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="&#xE706;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#EAB308"
                                       Width="28" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Launch at Login"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="White" />
                                <TextBlock Text="Start Speechy automatically when you log in"
                                           FontSize="12" Foreground="#A0A0B8" />
                            </StackPanel>
                            <CheckBox x:Name="LaunchAtLoginToggle" Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Checked="LaunchAtLogin_Changed"
                                      Unchecked="LaunchAtLogin_Changed" />
                        </Grid>

                        <!-- Divider -->
                        <Border Height="1" Background="#1AFFFFFF" Margin="16,0" />

                        <!-- Pause Media -->
                        <Grid Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="&#xE769;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#EC4899"
                                       Width="28" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Pause Media During Recording"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="White" />
                                <TextBlock Text="Automatically pause music when recording and resume when done"
                                           FontSize="12" Foreground="#A0A0B8"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <CheckBox x:Name="PauseMediaToggle" Grid.Column="2"
                                      VerticalAlignment="Center"
                                      Checked="PauseMedia_Changed"
                                      Unchecked="PauseMedia_Changed" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
