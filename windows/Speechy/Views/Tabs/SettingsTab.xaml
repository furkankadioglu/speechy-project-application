<UserControl x:Class="Speechy.Views.Tabs.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Speechy.Views.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="20">

            <!-- ========== Section: Push-to-Talk Hotkeys ========== -->
            <StackPanel Margin="0,0,0,20">
                <!-- Section Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE765;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#3B82F6"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Hotkeys"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <!-- Slot 1 (Blue) -->
                <controls:SlotConfigControl x:Name="Slot1Config" Margin="0,0,0,12" />

                <!-- Slot 2 (Green) -->
                <controls:SlotConfigControl x:Name="Slot2Config" Margin="0,0,0,0" />
            </StackPanel>

            <!-- ========== Section: Toggle Hotkeys ========== -->
            <StackPanel Margin="0,0,0,20">
                <!-- Section Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE765;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#F97316"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="Toggle Hotkeys (press again to stop)"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <!-- Slot 3 (Orange) -->
                <controls:SlotConfigControl x:Name="Slot3Config" Margin="0,0,0,12" />

                <!-- Slot 4 (Red/Purple) -->
                <controls:SlotConfigControl x:Name="Slot4Config" Margin="0,0,0,0" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
