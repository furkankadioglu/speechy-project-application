<UserControl x:Class="Speechy.Views.Tabs.LogsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#0D0D12">
        <DockPanel LastChildFill="True" VerticalAlignment="Stretch">

            <!-- Header bar -->
            <Border DockPanel.Dock="Top" Background="#1A1A2E" Padding="12,8"
                    BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Foreground="#22C55E"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Application Logs"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="ClearLogsButton"
                            Style="{StaticResource IconButton}"
                            ToolTip="Clear log display"
                            Click="ClearLogsButton_Click">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="11" Foreground="#6B7280" />
                    </Button>
                </Grid>
            </Border>

            <!-- Log content -->
            <ScrollViewer x:Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="#0D0D12">
                <TextBlock x:Name="LogTextBlock"
                           FontFamily="Consolas, Courier New"
                           FontSize="11"
                           Foreground="#B0B8C8"
                           Padding="12"
                           TextWrapping="NoWrap" />
            </ScrollViewer>

        </DockPanel>
    </Grid>
</UserControl>
