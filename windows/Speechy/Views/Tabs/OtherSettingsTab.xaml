<UserControl x:Class="Speechy.Views.Tabs.OtherSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">
        <StackPanel Margin="20">

            <!-- ========== Section: App Language ========== -->
            <StackPanel Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="&#xE774;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#3B82F6"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBlock Text="App Language"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" />
                </StackPanel>

                <TextBlock x:Name="LanguageDescText"
                           Text="Select the language for the user interface."
                           FontSize="12" Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <Border Background="#2D2D42" CornerRadius="12"
                        BorderBrush="#14FFFFFF" BorderThickness="1">
                    <StackPanel x:Name="LanguageListPanel">
                        <!-- Language rows generated in code-behind -->
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
