<Window x:Class="Speechy.Views.PermissionCheckWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speechy - Permissions"
        Width="440" Height="520"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True">

    <Border CornerRadius="16" ClipToBounds="True" Background="#1E1E2E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <!-- Header icon: orange-red gradient circle with shield -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                <Grid Width="70" Height="70" HorizontalAlignment="Center">
                    <Ellipse>
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F97316" Offset="0" />
                                <GradientStop Color="#EF4444" Offset="1" />
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="&#xEA18;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="30"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </StackPanel>

            <!-- Title and description -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,16,0,0">
                <TextBlock Text="Permissions Required"
                           FontSize="24" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock Text="Speechy needs the following permissions to work properly."
                           FontSize="13" Foreground="#A0A0B8"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="40,0,40,0" />
            </StackPanel>

            <!-- Permission rows -->
            <StackPanel Grid.Row="3" Margin="28,28,28,0">
                <!-- Microphone Permission -->
                <Border x:Name="MicPermissionCard" Background="#2D2D42" CornerRadius="12"
                        Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Status icon circle -->
                        <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,14,0">
                            <Ellipse x:Name="MicIconBg" Fill="#1A22C55E" />
                            <TextBlock x:Name="MicIcon" Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="20" Foreground="#22C55E"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <!-- Text -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Microphone"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" Margin="0,0,0,3" />
                            <TextBlock Text="Required to record your voice for transcription."
                                       FontSize="12" Foreground="#A0A0B8"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Status badge -->
                        <Border x:Name="MicBadge" Grid.Column="2"
                                Background="#1A22C55E" CornerRadius="6"
                                Padding="8,4" VerticalAlignment="Center">
                            <TextBlock x:Name="MicBadgeText" Text="Granted"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#22C55E" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Keyboard Hook Permission -->
                <Border x:Name="KeyboardPermissionCard" Background="#2D2D42" CornerRadius="12"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,14,0">
                            <Ellipse x:Name="KeyboardIconBg" Fill="#1A22C55E" />
                            <TextBlock x:Name="KeyboardIcon" Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="20" Foreground="#22C55E"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Keyboard Access"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="White" Margin="0,0,0,3" />
                            <TextBlock Text="Required to detect global hotkeys for recording."
                                       FontSize="12" Foreground="#A0A0B8"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border x:Name="KeyboardBadge" Grid.Column="2"
                                Background="#1A22C55E" CornerRadius="6"
                                Padding="8,4" VerticalAlignment="Center">
                            <TextBlock x:Name="KeyboardBadgeText" Text="Granted"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#22C55E" />
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel Grid.Row="4" Margin="0,24,0,0" HorizontalAlignment="Center">
                <!-- Open Settings button (shown when permissions missing) -->
                <Button x:Name="OpenSettingsButton" Width="300" Height="40"
                        Margin="0,0,0,10"
                        Style="{StaticResource PrimaryButton}"
                        Click="OpenSettings_Click"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Open System Settings"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Button>

                <!-- Check Again button -->
                <Button x:Name="CheckAgainButton" Width="300" Height="40"
                        Margin="0,0,0,10"
                        Style="{StaticResource SecondaryButton}"
                        Click="CheckAgain_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Check Again"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Button>

                <!-- Continue button (shown when all granted) -->
                <Button x:Name="ContinueButton" Width="300" Height="40"
                        Visibility="Collapsed"
                        Click="Continue_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="#22C55E" />
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="13" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Continue"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
