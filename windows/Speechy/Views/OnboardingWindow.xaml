<Window x:Class="Speechy.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to Speechy"
        Width="500" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="True">

    <Border CornerRadius="16" ClipToBounds="True" Background="#1E1E2E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Page Content Area -->
            <Grid Grid.Row="0">
                <!-- Page 0: Welcome -->
                <StackPanel x:Name="Page0" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Visible">
                    <!-- Gradient circle with mic icon -->
                    <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Ellipse>
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#007AFF" Offset="0" />
                                    <GradientStop Color="#AF52DE" Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="&#xE734;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="36"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="Welcome to Speechy"
                               FontSize="28" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="The fastest way to convert speech to text"
                               FontSize="16" Foreground="#A0A0B8"
                               HorizontalAlignment="Center" Margin="0,0,0,24" />

                    <!-- Feature rows -->
                    <StackPanel HorizontalAlignment="Center" Width="300">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE765;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#3B82F6"
                                       Width="24" VerticalAlignment="Center" />
                            <TextBlock Text="Instant recording with hotkeys"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE774;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#3B82F6"
                                       Width="24" VerticalAlignment="Center" />
                            <TextBlock Text="29 language support"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE945;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16" Foreground="#3B82F6"
                                       Width="24" VerticalAlignment="Center" />
                            <TextBlock Text="Fast AI-powered transcription"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Page 1: Permissions -->
                <StackPanel x:Name="Page1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <!-- Gradient circle with lock icon -->
                    <Grid Width="60" Height="60" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Ellipse>
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#22C55E" Offset="0" />
                                    <GradientStop Color="#16A34A" Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="&#xE72E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="26"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="Permissions Required"
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,16" />

                    <StackPanel Width="380" Margin="0,0,0,0">
                        <!-- Microphone permission card -->
                        <Border Background="#2D2D42" CornerRadius="10" Padding="16" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE720;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Foreground="#3B82F6"
                                           Width="30" VerticalAlignment="Top" Margin="0,2,12,0" />
                                <StackPanel>
                                    <TextBlock Text="Microphone Access"
                                               FontSize="15" FontWeight="SemiBold" Foreground="White"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="Microphone access is required to record your voice."
                                               FontSize="12" Foreground="#A0A0B8"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Accessibility permission card -->
                        <Border Background="#2D2D42" CornerRadius="10" Padding="16" Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FB;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Foreground="#F97316"
                                           Width="30" VerticalAlignment="Top" Margin="0,2,12,0" />
                                <StackPanel>
                                    <TextBlock Text="Keyboard Access"
                                               FontSize="15" FontWeight="SemiBold" Foreground="White"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="Keyboard hook permission is needed to detect global hotkeys for recording. Windows may prompt for admin access."
                                               FontSize="12" Foreground="#A0A0B8"
                                               TextWrapping="Wrap" MaxWidth="290" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Page 2: How to Use -->
                <StackPanel x:Name="Page2" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <!-- Gradient circle with keyboard icon -->
                    <Grid Width="60" Height="60" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Ellipse>
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#8B5CF6" Offset="0" />
                                    <GradientStop Color="#7C3AED" Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="&#xE765;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="26"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <TextBlock Text="How to Use"
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,16" />

                    <StackPanel Width="360" Margin="0,0,0,0">
                        <!-- Step 1 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Grid Width="28" Height="28" Margin="0,0,12,0">
                                <Ellipse Fill="#8B5CF6" />
                                <TextBlock Text="1" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="Click the tray icon in the system tray"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Step 2 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Grid Width="28" Height="28" Margin="0,0,12,0">
                                <Ellipse Fill="#8B5CF6" />
                                <TextBlock Text="2" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="Configure your hotkeys"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Step 3 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Grid Width="28" Height="28" Margin="0,0,12,0">
                                <Ellipse Fill="#8B5CF6" />
                                <TextBlock Text="3" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="Hold the hotkey and speak"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Step 4 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Grid Width="28" Height="28" Margin="0,0,12,0">
                                <Ellipse Fill="#8B5CF6" />
                                <TextBlock Text="4" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock Text="Release to paste the text!"
                                       FontSize="14" Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="Default: Alt &#x2192; English, Shift &#x2192; Turkish"
                               FontSize="12" Foreground="#6B6B80"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <!-- Bottom Navigation -->
            <Grid Grid.Row="1" Margin="20,0,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Back button -->
                <Button x:Name="BackButton" Grid.Column="0"
                        Content="Back" Visibility="Collapsed"
                        Style="{StaticResource SecondaryButton}"
                        Click="BackButton_Click" />

                <!-- Page dots -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot0" Width="8" Height="8"
                             Fill="#3B82F6" Margin="0,0,8,0" />
                    <Ellipse x:Name="Dot1" Width="8" Height="8"
                             Fill="#4D4D66" Margin="0,0,8,0" />
                    <Ellipse x:Name="Dot2" Width="8" Height="8"
                             Fill="#4D4D66" />
                </StackPanel>

                <!-- Next / Get Started button -->
                <Button x:Name="NextButton" Grid.Column="2"
                        Content="Next"
                        Style="{StaticResource PrimaryButton}"
                        Click="NextButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
