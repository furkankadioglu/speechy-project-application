<UserControl x:Class="Speechy.Views.Controls.SlotConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="SlotControl">

    <Border x:Name="CardBorder" CornerRadius="12" Padding="16"
            Background="#2D2D42" BorderThickness="1">
        <StackPanel>
            <!-- Header row: toggle + title + shortcut display -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Enable/disable toggle -->
                <CheckBox x:Name="EnableToggle" Grid.Column="0"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Checked="EnableToggle_Changed"
                          Unchecked="EnableToggle_Changed">
                    <CheckBox.LayoutTransform>
                        <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
                    </CheckBox.LayoutTransform>
                </CheckBox>

                <!-- Title with colored dot -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,8,0" />
                    <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold"
                               Foreground="White" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Shortcut display badge -->
                <Border x:Name="ShortcutBadge" Grid.Column="3"
                        CornerRadius="8" Padding="10,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ShortcutText"
                                   FontSize="13" FontFamily="Consolas" FontWeight="Medium"
                                   Foreground="White" VerticalAlignment="Center" />
                        <TextBlock x:Name="FlagText"
                                   FontSize="13" Margin="6,0,0,0"
                                   VerticalAlignment="Center" />
                        <Border x:Name="ModeBadge" CornerRadius="4"
                                Padding="6,2" Margin="6,0,0,0">
                            <TextBlock x:Name="ModeText"
                                       FontSize="10" FontWeight="Medium" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Modifier key toggles: Shift, Ctrl, Alt, Win -->
            <UniformGrid x:Name="ModifierGrid" Rows="1" Columns="4" Margin="0,0,0,14">
                <Button x:Name="ShiftButton" Content="Shift" Margin="0,0,3,0"
                        Height="40" Click="ShiftButton_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="modBorder" CornerRadius="8"
                                    BorderThickness="1"
                                    Background="#252538"
                                    BorderBrush="#1AFFFFFF">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="18" FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="CtrlButton" Content="Ctrl" Margin="3,0,3,0"
                        Height="40" Click="CtrlButton_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="modBorder" CornerRadius="8"
                                    BorderThickness="1"
                                    Background="#252538"
                                    BorderBrush="#1AFFFFFF">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="18" FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="AltButton" Content="Alt" Margin="3,0,3,0"
                        Height="40" Click="AltButton_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="modBorder" CornerRadius="8"
                                    BorderThickness="1"
                                    Background="#252538"
                                    BorderBrush="#1AFFFFFF">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="18" FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="WinButton" Content="Win" Margin="3,0,0,0"
                        Height="40" Click="WinButton_Click" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="modBorder" CornerRadius="8"
                                    BorderThickness="1"
                                    Background="#252538"
                                    BorderBrush="#1AFFFFFF">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="18" FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </UniformGrid>

            <!-- Language picker -->
            <Border Background="#1E1E2E" CornerRadius="8" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE774;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14" Foreground="#A0A0B8"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                    <ComboBox x:Name="LanguageCombo"
                              Style="{StaticResource DarkComboBox}"
                              MinWidth="200"
                              SelectionChanged="LanguageCombo_SelectionChanged" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
