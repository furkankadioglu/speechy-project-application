<Window x:Class="Speechy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:Speechy.Views.Tabs"
        xmlns:vm="clr-namespace:Speechy.ViewModels"
        Title="Speechy Settings"
        Width="672" Height="816"
        MinWidth="560" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        ResizeMode="CanResize">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar: 168px -->
            <ColumnDefinition Width="168" />
            <!-- Divider -->
            <ColumnDefinition Width="1" />
            <!-- Content -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Column="0" Background="#19FFFFFF">
            <DockPanel>
                <!-- Quit button at bottom -->
                <Button DockPanel.Dock="Bottom"
                        Margin="16,0,16,16"
                        Cursor="Hand"
                        Click="QuitButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="#1AEF4444"
                                    CornerRadius="8" Padding="16,8">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE7E8;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#CCEF4444"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Quit"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="#CCEF4444" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#33EF4444" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Top section: logo + nav -->
                <StackPanel>
                    <!-- Logo -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,20,0,24">
                        <Grid Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Ellipse>
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#007AFF" Offset="0" />
                                        <GradientStop Color="#AF52DE" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="&#xE720;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="Speechy"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Navigation Items -->
                    <StackPanel Margin="8,0">
                        <!-- Settings -->
                        <Button x:Name="NavSettings" Click="NavSettings_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="navBorder" CornerRadius="8"
                                            Padding="12,10" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE713;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" FontWeight="Medium"
                                                       Width="20"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Settings"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Advanced -->
                        <Button x:Name="NavAdvanced" Click="NavAdvanced_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="navBorder" CornerRadius="8"
                                            Padding="12,10" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE9E9;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" FontWeight="Medium"
                                                       Width="20"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Advanced"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- History -->
                        <Button x:Name="NavHistory" Click="NavHistory_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="navBorder" CornerRadius="8"
                                            Padding="12,10" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE823;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" FontWeight="Medium"
                                                       Width="20"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="History"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- License -->
                        <Button x:Name="NavLicense" Click="NavLicense_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="navBorder" CornerRadius="8"
                                            Padding="12,10" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE192;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" FontWeight="Medium"
                                                       Width="20"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="License"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Prompt -->
                        <Button x:Name="NavPrompt" Click="NavPrompt_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="navBorder" CornerRadius="8"
                                            Padding="12,10" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE70B;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14" FontWeight="Medium"
                                                       Width="20"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="Prompt"
                                                       FontSize="13" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="#1AFFFFFF" />

        <!-- ===== CONTENT AREA ===== -->
        <Grid Grid.Column="2">
            <tabs:SettingsTab x:Name="SettingsTabContent" Visibility="Visible" />
            <tabs:AdvancedTab x:Name="AdvancedTabContent" Visibility="Collapsed" />
            <tabs:HistoryTab x:Name="HistoryTabContent" Visibility="Collapsed" />
            <tabs:LicenseTab x:Name="LicenseTabContent" Visibility="Collapsed" />
            <tabs:PromptTab x:Name="PromptTabContent" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
