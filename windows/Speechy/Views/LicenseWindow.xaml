<Window x:Class="Speechy.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Speechy - Activate"
        Width="440" Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="True">

    <Border CornerRadius="16" ClipToBounds="True" Background="#1E1E2E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Center content -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Gradient circle with key icon -->
                <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse>
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#007AFF" Offset="0" />
                                <GradientStop Color="#AF52DE" Offset="1" />
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- Key icon -->
                    <TextBlock Text="&#xE192;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="34"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>

                <!-- Title -->
                <TextBlock Text="Speechy"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <TextBlock Text="Enter your license key to get started"
                           FontSize="14"
                           Foreground="#A0A0B8"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />

                <!-- License Key label -->
                <TextBlock Text="License Key"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#A0A0B8"
                           Margin="0,0,0,8" />

                <!-- License key input -->
                <TextBox x:Name="LicenseKeyInput"
                         Width="340"
                         Style="{StaticResource DarkTextBox}"
                         FontFamily="Consolas"
                         FontSize="14"
                         KeyDown="LicenseKeyInput_KeyDown" />

                <!-- Error message -->
                <StackPanel x:Name="ErrorPanel" Orientation="Horizontal"
                            Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="#EF4444"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock x:Name="ErrorText"
                               FontSize="12"
                               Foreground="#EF4444"
                               TextWrapping="Wrap"
                               MaxWidth="320" />
                </StackPanel>

                <!-- Success message -->
                <StackPanel x:Name="SuccessPanel" Orientation="Horizontal"
                            Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="&#xE73E;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="#22C55E"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock Text="License activated successfully!"
                               FontSize="12"
                               Foreground="#22C55E" />
                </StackPanel>

                <!-- Activate button -->
                <Button x:Name="ActivateButton"
                        Width="340" Height="40"
                        Margin="0,16,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Click="ActivateButton_Click"
                        IsEnabled="False">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="ActivateSpinner"
                                   Text="&#xE117;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="Collapsed">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotation" CenterX="7" CenterY="7" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="ActivateButtonText"
                                   Text="Activate License"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Footer -->
            <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,24">
                <TextBlock Text="Don't have a license?"
                           FontSize="12"
                           Foreground="#6B6B80"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="TrialLink"
                           Text="Get a free trial at speechy.frkn.com.tr"
                           FontSize="12"
                           FontWeight="Medium"
                           Foreground="#3B82F6"
                           HorizontalAlignment="Center"
                           Cursor="Hand"
                           MouseLeftButtonDown="TrialLink_Click">
                    <TextBlock.TextDecorations>
                        <TextDecorationCollection />
                    </TextBlock.TextDecorations>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
